# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# Optional: Dedicated IPFS gateway URL (e.g. Filebase, Pinata)
# Falls back to public gateways if not set
ENVIO_IPFS_GATEWAY_URL=""

# Optional: Paid RPC URLs per chain (used for VE contract discovery)
# Falls back to public RPCs if not set
ENVIO_RPC_URL_1=""
ENVIO_RPC_URL_137=""
ENVIO_RPC_URL_42161=""
ENVIO_RPC_URL_8453=""
ENVIO_RPC_URL_11155111=""
ENVIO_RPC_URL_324=""
